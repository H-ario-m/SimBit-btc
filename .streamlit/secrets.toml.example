# Streamlit Secrets template for cloud deployment
# Instructions:
# 1. Go to share.streamlit.io -> Your App -> Settings -> Secrets
# 2. Paste your actual DATABASE_URL from Supabase below

[database]
DATABASE_URL = "postgresql://postgres.<your-project-ref>:<your-password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres"
